		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--8)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--6)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--6)"
			}
		},
		"css": ":root { --luka-bp-sm: 640px; --luka-bp-md: 768px; --luka-bp-lg: 1024px; --luka-bp-xl: 1280px; --luka-bp-2xl: 1536px; --luka-transition: 220ms ease; --luka-transition-slow: 400ms ease; --luka-radius-sm: 0.25rem; --luka-radius-md: 0.5rem; --luka-radius-lg: 1rem; --luka-radius-xl: 1.5rem; --luka-radius-full: 9999px; } *:focus-visible { outline: 2px solid var(--wp--preset--color--accent); outline-offset: 3px; border-radius: 2px; } @media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }",
